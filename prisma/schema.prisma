generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String               @id @default(cuid())
  email          String               @unique
  passwordHash   String
  name           String
  connectBalance Int                  @default(50)
  walletBalance  Int                  @default(0)
  paymentVerified Boolean             @default(false)
  rating         Float?
  totalSpent     Int                  @default(0)
  country        String?
  activeRole     Role                 @default(FREELANCER)
  onlineForMessages Boolean           @default(true)
  createdAt      DateTime             @default(now())

  title                String?
  overview             String?
  hourlyRate           Int?
  city                 String?
  avatarUrl            String?
  videoIntroUrl        String?
  responseTime         String?
  skills               String[]
  hoursPerWeek         HoursPerWeek?
  openToContractToHire Boolean        @default(false)
  idVerified           Boolean        @default(false)
  phoneVerified        Boolean        @default(false)
  militaryVeteran      Boolean        @default(false)
  availabilityBadge    Boolean        @default(false)
  boostProfile         Boolean        @default(false)
  showWorkHistory      Boolean        @default(true)

  jobs             Job[]
  bids             Bid[]
  transactions     ConnectTransaction[]
  languages        Language[]
  educations       Education[]
  employments      Employment[]
  portfolioItems   PortfolioItem[]
  certifications   Certification[]
  licenses         License[]
  linkedAccounts   LinkedAccount[]
  otherExperiences OtherExperience[]
  reviewsReceived  Review[]             @relation("FreelancerReviews")
  reviewsAuthored  Review[]             @relation("ClientReviews")
  savedJobs        SavedJob[]
  clientContracts     Contract[]        @relation("ClientContracts")
  freelancerContracts Contract[]        @relation("FreelancerContracts")
  clientFeedbackReceived ClientFeedback[] @relation("ClientFeedbackReceived")
  clientFeedbackGiven    ClientFeedback[] @relation("ClientFeedbackGiven")
  walletTransactions  WalletTransaction[]
  clientConversations     Conversation[] @relation("ClientConversations")
  freelancerConversations Conversation[] @relation("FreelancerConversations")
  messages            Message[]
}

model Language {
  id          String              @id @default(cuid())
  name        String
  proficiency LanguageProficiency
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Education {
  id           String  @id @default(cuid())
  school       String
  degree       String?
  fieldOfStudy String?
  startYear    Int?
  endYear      Int?
  userId       String
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Employment {
  id          String  @id @default(cuid())
  company     String
  title       String
  startDate   String?
  endDate     String?
  current     Boolean @default(false)
  description String?
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PortfolioItem {
  id          String  @id @default(cuid())
  title       String
  description String?
  category    String?
  imageUrl    String?
  projectUrl  String?
  published   Boolean @default(true)
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Certification {
  id     String  @id @default(cuid())
  name   String
  issuer String?
  year   Int?
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model License {
  id     String  @id @default(cuid())
  name   String
  issuer String?
  year   Int?
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LinkedAccount {
  id       String  @id @default(cuid())
  provider String
  username String
  url      String?
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OtherExperience {
  id          String  @id @default(cuid())
  subject     String
  description String?
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Review {
  id           String   @id @default(cuid())
  rating       Int
  comment      String
  endorsements String[]
  amount       Int
  priceType    JobType
  createdAt    DateTime @default(now())
  jobId        String   @unique
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  authorId     String
  author       User     @relation("ClientReviews", fields: [authorId], references: [id], onDelete: Cascade)
  freelancerId String
  freelancer   User     @relation("FreelancerReviews", fields: [freelancerId], references: [id], onDelete: Cascade)

  @@index([freelancerId])
}

model Job {
  id              String          @id @default(cuid())
  title           String
  description     String
  budget          Int?
  jobType         JobType         @default(FIXED)
  experienceLevel ExperienceLevel @default(ENTRY)
  category        String?
  projectTerm     ProjectTerm?
  scopeSize       ScopeSize?
  duration        JobDuration?
  contractToHire  Boolean         @default(false)
  hourlyRateMin   Int?
  hourlyRateMax   Int?
  connectsRequired Int            @default(10)
  lastViewedAt    DateTime?
  skills          String[]
  status          JobStatus       @default(OPEN)
  createdAt       DateTime        @default(now())
  ownerId         String
  owner           User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  bids            Bid[]
  review          Review?
  savedBy         SavedJob[]
  contracts       Contract[]
  conversations   Conversation[]

  @@index([status, createdAt])
  @@index([ownerId])
}

model SavedJob {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
}

model Bid {
  id           String    @id @default(cuid())
  amount       Int
  coverLetter  String
  connectsSpent Int
  boostConnects Int      @default(0)
  status       BidStatus @default(PENDING)
  interviewing Boolean   @default(false)
  createdAt    DateTime  @default(now())
  jobId        String
  job          Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  freelancerId String
  freelancer   User      @relation(fields: [freelancerId], references: [id], onDelete: Cascade)
  contracts    Contract[]

  @@unique([jobId, freelancerId])
  @@index([freelancerId, status])
}

model Contract {
  id           String         @id @default(cuid())
  type         JobType
  hourlyRate   Int?
  offerMessage String?
  status       ContractStatus @default(OFFERED)
  createdAt    DateTime       @default(now())
  acceptedAt   DateTime?
  endedAt      DateTime?
  endedById    String?
  jobId        String
  job          Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  bidId        String
  bid          Bid            @relation(fields: [bidId], references: [id], onDelete: Cascade)
  clientId     String
  client       User           @relation("ClientContracts", fields: [clientId], references: [id], onDelete: Cascade)
  freelancerId String
  freelancer   User           @relation("FreelancerContracts", fields: [freelancerId], references: [id], onDelete: Cascade)
  milestones   Milestone[]
  timeEntries  TimeEntry[]
  clientFeedback ClientFeedback?
  conversation Conversation?
  messages     Message[]

  @@index([clientId])
  @@index([freelancerId])
  @@index([bidId])
  @@index([jobId])
}

model Conversation {
  id                 String    @id @default(cuid())
  createdAt          DateTime  @default(now())
  lastMessageAt      DateTime  @default(now())
  clientLastReadAt   DateTime?
  freelancerLastReadAt DateTime?
  clientFavorite     Boolean   @default(false)
  freelancerFavorite Boolean   @default(false)
  clientNote         String?
  freelancerNote     String?
  jobId              String
  job                Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  clientId           String
  client             User      @relation("ClientConversations", fields: [clientId], references: [id], onDelete: Cascade)
  freelancerId       String
  freelancer         User      @relation("FreelancerConversations", fields: [freelancerId], references: [id], onDelete: Cascade)
  contractId         String?   @unique
  contract           Contract? @relation(fields: [contractId], references: [id])
  messages           Message[]

  @@unique([jobId, freelancerId])
  @@index([clientId])
  @@index([freelancerId])
}

model Message {
  id             String       @id @default(cuid())
  type           MessageType  @default(TEXT)
  body           String
  createdAt      DateTime     @default(now())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  contractId     String?
  contract       Contract?    @relation(fields: [contractId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
}

model Milestone {
  id                String          @id @default(cuid())
  description       String
  amount            Int
  order             Int
  status            MilestoneStatus @default(PENDING)
  submissionMessage String?
  changeRequest     String?
  submittedAt       DateTime?
  approvedAt        DateTime?
  createdAt         DateTime        @default(now())
  contractId        String
  contract          Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
}

model TimeEntry {
  id         String          @id @default(cuid())
  date       String
  hours      Float
  memo       String
  status     TimeEntryStatus @default(LOGGED)
  createdAt  DateTime        @default(now())
  contractId String
  contract   Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
}

model ClientFeedback {
  id           String   @id @default(cuid())
  rating       Int
  comment      String
  createdAt    DateTime @default(now())
  contractId   String   @unique
  contract     Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  clientId     String
  client       User     @relation("ClientFeedbackReceived", fields: [clientId], references: [id], onDelete: Cascade)
  freelancerId String
  freelancer   User     @relation("ClientFeedbackGiven", fields: [freelancerId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model WalletTransaction {
  id         String       @id @default(cuid())
  amount     Int
  reason     WalletReason
  contractId String?
  createdAt  DateTime     @default(now())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ConnectTransaction {
  id        String        @id @default(cuid())
  amount    Int
  reason    TransactionReason
  createdAt DateTime      @default(now())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum JobStatus {
  OPEN
  CLOSED
}

enum JobType {
  FIXED
  HOURLY
}

enum ExperienceLevel {
  ENTRY
  INTERMEDIATE
  EXPERT
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum TransactionReason {
  TOPUP
  BID
}

enum HoursPerWeek {
  AS_NEEDED
  LESS_THAN_30
  MORE_THAN_30
}

enum LanguageProficiency {
  BASIC
  CONVERSATIONAL
  FLUENT
  NATIVE_OR_BILINGUAL
}

enum Role {
  FREELANCER
  CLIENT
}

enum ScopeSize {
  LARGE
  MEDIUM
  SMALL
}

enum ProjectTerm {
  LONG_TERM
  SHORT_TERM
}

enum JobDuration {
  MORE_THAN_6_MONTHS
  THREE_TO_SIX_MONTHS
  ONE_TO_THREE_MONTHS
}

enum ContractStatus {
  OFFERED
  ACTIVE
  DECLINED
  WITHDRAWN
  ENDED
}

enum MilestoneStatus {
  PENDING
  FUNDED
  SUBMITTED
  CHANGES_REQUESTED
  APPROVED
  CANCELLED
}

enum TimeEntryStatus {
  LOGGED
  PAID
}

enum WalletReason {
  TOPUP
  ESCROW_FUND
  ESCROW_REFUND
  MILESTONE_PAYOUT
  HOURLY_PAYOUT
}

enum MessageType {
  TEXT
  OFFER
}
