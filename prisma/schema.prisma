generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String               @id @default(cuid())
  email          String               @unique
  passwordHash   String
  name           String
  connectBalance Int                  @default(50)
  paymentVerified Boolean             @default(false)
  rating         Float?
  totalSpent     Int                  @default(0)
  country        String?
  activeRole     Role                 @default(FREELANCER)
  onlineForMessages Boolean           @default(true)
  createdAt      DateTime             @default(now())

  title                String?
  overview             String?
  hourlyRate           Int?
  city                 String?
  avatarUrl            String?
  videoIntroUrl        String?
  responseTime         String?
  skills               String[]
  hoursPerWeek         HoursPerWeek?
  openToContractToHire Boolean        @default(false)
  idVerified           Boolean        @default(false)
  phoneVerified        Boolean        @default(false)
  militaryVeteran      Boolean        @default(false)
  availabilityBadge    Boolean        @default(false)
  boostProfile         Boolean        @default(false)
  showWorkHistory      Boolean        @default(true)

  jobs             Job[]
  bids             Bid[]
  transactions     ConnectTransaction[]
  languages        Language[]
  educations       Education[]
  employments      Employment[]
  portfolioItems   PortfolioItem[]
  certifications   Certification[]
  licenses         License[]
  linkedAccounts   LinkedAccount[]
  otherExperiences OtherExperience[]
  reviewsReceived  Review[]             @relation("FreelancerReviews")
  reviewsAuthored  Review[]             @relation("ClientReviews")
  savedJobs        SavedJob[]
}

model Language {
  id          String              @id @default(cuid())
  name        String
  proficiency LanguageProficiency
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Education {
  id           String  @id @default(cuid())
  school       String
  degree       String?
  fieldOfStudy String?
  startYear    Int?
  endYear      Int?
  userId       String
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Employment {
  id          String  @id @default(cuid())
  company     String
  title       String
  startDate   String?
  endDate     String?
  current     Boolean @default(false)
  description String?
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PortfolioItem {
  id          String  @id @default(cuid())
  title       String
  description String?
  category    String?
  imageUrl    String?
  projectUrl  String?
  published   Boolean @default(true)
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Certification {
  id     String  @id @default(cuid())
  name   String
  issuer String?
  year   Int?
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model License {
  id     String  @id @default(cuid())
  name   String
  issuer String?
  year   Int?
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LinkedAccount {
  id       String  @id @default(cuid())
  provider String
  username String
  url      String?
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OtherExperience {
  id          String  @id @default(cuid())
  subject     String
  description String?
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Review {
  id           String   @id @default(cuid())
  rating       Int
  comment      String
  endorsements String[]
  amount       Int
  priceType    JobType
  createdAt    DateTime @default(now())
  jobId        String   @unique
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  authorId     String
  author       User     @relation("ClientReviews", fields: [authorId], references: [id], onDelete: Cascade)
  freelancerId String
  freelancer   User     @relation("FreelancerReviews", fields: [freelancerId], references: [id], onDelete: Cascade)

  @@index([freelancerId])
}

model Job {
  id              String          @id @default(cuid())
  title           String
  description     String
  budget          Int?
  jobType         JobType         @default(FIXED)
  experienceLevel ExperienceLevel @default(ENTRY)
  category        String?
  projectTerm     ProjectTerm?
  scopeSize       ScopeSize?
  duration        JobDuration?
  contractToHire  Boolean         @default(false)
  hourlyRateMin   Int?
  hourlyRateMax   Int?
  connectsRequired Int            @default(10)
  lastViewedAt    DateTime?
  skills          String[]
  status          JobStatus       @default(OPEN)
  createdAt       DateTime        @default(now())
  ownerId         String
  owner           User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  bids            Bid[]
  review          Review?
  savedBy         SavedJob[]

  @@index([status, createdAt])
  @@index([ownerId])
}

model SavedJob {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
}

model Bid {
  id           String    @id @default(cuid())
  amount       Int
  coverLetter  String
  connectsSpent Int
  boostConnects Int      @default(0)
  status       BidStatus @default(PENDING)
  createdAt    DateTime  @default(now())
  jobId        String
  job          Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  freelancerId String
  freelancer   User      @relation(fields: [freelancerId], references: [id], onDelete: Cascade)

  @@unique([jobId, freelancerId])
  @@index([freelancerId, status])
}

model ConnectTransaction {
  id        String        @id @default(cuid())
  amount    Int
  reason    TransactionReason
  createdAt DateTime      @default(now())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum JobStatus {
  OPEN
  CLOSED
}

enum JobType {
  FIXED
  HOURLY
}

enum ExperienceLevel {
  ENTRY
  INTERMEDIATE
  EXPERT
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum TransactionReason {
  TOPUP
  BID
}

enum HoursPerWeek {
  AS_NEEDED
  LESS_THAN_30
  MORE_THAN_30
}

enum LanguageProficiency {
  BASIC
  CONVERSATIONAL
  FLUENT
  NATIVE_OR_BILINGUAL
}

enum Role {
  FREELANCER
  CLIENT
}

enum ScopeSize {
  LARGE
  MEDIUM
  SMALL
}

enum ProjectTerm {
  LONG_TERM
  SHORT_TERM
}

enum JobDuration {
  MORE_THAN_6_MONTHS
  THREE_TO_SIX_MONTHS
  ONE_TO_THREE_MONTHS
}
